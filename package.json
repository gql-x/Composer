{
	"name": "@gql-x/composer",
	"description": "An extensible DSL for composing GraphQL strings with nicer DX",
	"version": "0.0.0-pre-202605261139",
	"main": "./src/composer.js",
	"type": "module",
	"scripts": {
		"test": "node test/runner.js"
	},
	"browser": {
		"@gql-x/composer": "./src/composer.js"
	},
	"exports": {
		".": {
			"types": "./src/composer.d.ts",
			"default": "./src/composer.js"
		},
		"./composer": {
			"types": "./src/composer.d.ts",
			"default": "./src/composer.js"
		},
		"./db": {
			"types": "./src/db.d.ts",
			"default": "./src/db.js"
		}
	},
	"repository": {
		"url": "git+https://github.com/gql-x/composer.git"
	},
	"bugs": {
		"url": "https://github.com/gql-x/composer/issues",
		"email": "getify@gmail.com"
	},
	"homepage": "https://github.com/gql-x/composer",
	"author": "Kyle Simpson <getify@gmail.com>",
	"license": "MIT"
}
